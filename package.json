{
  "name": "rpg-reactor",
  "version": "0.1.0",
  "description": "An open-source, cross-platform RPG game engine",
  "main": "index.html",
  "scripts": {
    "start": "nw .",
    "dev": "nw ."
  },
  "window": {
    "title": "RPG Reactor",
    "width": 1280,
    "height": 720,
    "min_width": 800,
    "min_height": 600,
    "icon": "images/icon.png",
    "show_devtools": true,
    "toolbar": false
  },
  "chromium-args": "--enable-logging --disable-direct-composition",
  "webkit": {
    "plugin": true
  },
  "dependencies": {
    "pixi.js": "^8.0.0"
  },
  "keywords": [
    "rpg",
    "game-engine",
    "cross-platform",
    "nwjs",
    "pixijs"
  ],
  "author": "",
  "license": "CC0-1.0"
}
